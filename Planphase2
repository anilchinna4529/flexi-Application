model Project {
  id               String   @id @default(cuid())
  projectRequestId String
  name             String
  status           String   @default("ONBOARDING")
  startAt          DateTime?
  endAt            DateTime?
  createdAt        DateTime @default(now())

  request          ProjectRequest @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)
  milestones       Milestone[]
}

model Milestone {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  status         String   @default("PENDING")
  dueAt          DateTime?
  createdAt      DateTime @default(now())

  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TrainingProgram {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String
  level          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modules        TrainingModule[]
  enrollments    Enrollment[]
  resources      LearningResource[]
}

model TrainingModule {
  id                String   @id @default(cuid())
  trainingProgramId String
  title             String
  content           String?
  videoUrl          String?
  sortOrder         Int      @default(0)

  program           TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id                String   @id @default(cuid())
  userId            String
  trainingProgramId String
  status            String   @default("ACTIVE")
  progressPct       Int      @default(0)
  enrolledAt        DateTime @default(now())

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program           TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingProgramId])
}

model LearningResource {
  id                String   @id @default(cuid())
  trainingProgramId String
  title             String
  url               String
  type              String

  program           TrainingProgram @relation(fields: [trainingProgramId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id             String       @id @default(cuid())
  userId         String
  subject        String
  status         TicketStatus @default(OPEN)
  priority       String       @default("MEDIUM")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       TicketMessage[]
}

model TicketMessage {
  id             String   @id @default(cuid())
  ticketId       String
  senderUserId   String?
  message        String
  createdAt      DateTime @default(now())

  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String   @id @default(cuid())
  userId         String
  type           String
  title          String
  body           String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UploadedFile {
  id             String   @id @default(cuid())
  userId         String?
  storageKey     String
  fileName       String
  mimeType       String
  sizeBytes      Int
  createdAt      DateTime @default(now())

  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
